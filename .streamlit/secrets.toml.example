# Admin only — copy to secrets.toml locally OR paste in Streamlit Cloud → Secrets
# Trainers never see this file.

OPENAI_API_KEY = "sk-..."

# LLM alignment judge (primary QC layer)
QC_LLM_MODEL = "gpt-4.1"
# Alternatives: "gpt-5.1" if your org has access, "o4-mini" for reasoning-heavy review

# Terminus Task Tracker sheet — matches Apps Script v2 constants
[sheet]
url = "https://docs.google.com/spreadsheets/d/1XR_EFXtUt4GQ_d6zlkPT4arZi-BG-zFGHx4ctSSG51s/edit"
worksheet = "May 1st - 31st"
task_col = "Task Name"
instruction_col = "Task Instruction"
trainer_col = "Trainer Name"
instruction_col_index = "16"
# spec_col = ""
