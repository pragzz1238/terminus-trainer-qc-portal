# Admin only — paste in Streamlit Cloud → Settings → Secrets
# Trainers never see this file.

OPENAI_API_KEY = "sk-proj-..."

# LLM alignment judge (primary QC layer)
QC_LLM_MODEL = "gpt-5.2"
QC_EMBED_MODEL = "text-embedding-3-small"
# Concurrent LLM alignment checks (1–9, default 6)
QC_LLM_PARALLEL = "6"

# Do NOT set OPENAI_BASE_URL for direct OpenAI keys (uses api.openai.com automatically).
# Remove OPENROUTER_API_KEY / openrouter base URL if you switched back to OpenAI.

# Terminus Task Tracker sheet
[sheet]
url = "https://docs.google.com/spreadsheets/d/1XR_EFXtUt4GQ_d6zlkPT4arZi-BG-zFGHx4ctSSG51s/edit"
worksheet = "May 1st - 31st"
task_col = "Task name"
instruction_col = "Task Instruction"
trainer_col = "Trainer Name"
instruction_col_index = "16"

# --- Optional: OpenRouter instead of OpenAI ---
# OPENROUTER_API_KEY = "sk-or-v1-..."
# OPENAI_BASE_URL = "https://openrouter.ai/api/v1"
# QC_LLM_MODEL = "openai/gpt-5.2"
# QC_EMBED_MODEL = "openai/text-embedding-3-small"
